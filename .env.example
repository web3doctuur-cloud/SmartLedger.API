# Database Connection (PostgreSQL/Neon)
ConnectionStrings__DefaultConnection=Host=localhost;Database=SmartLedgerDb;Username=postgres;Password=yourpassword

# JWT Settings
JwtSettings__Secret=YourSuperSecretKeyAtLeast32CharactersLong
JwtSettings__Issuer=SmartLedgerAPI
JwtSettings__Audience=SmartLedgerClient

# Environment
ASPNETCORE_ENVIRONMENT=Development